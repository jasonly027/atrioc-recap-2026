            "description": "Chatters that appeared on screen"
          },

          "games": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "duration"],
              "properties": {
                "name": {
                  "type": "string",
                  "enum": [
                    "Warcraft III",
                    "Age of Empires II",
                    "Hitman 3",
                    "007 First Light",
                    "Monkey Ball",
                    "Slay the Spire 2"
                  ]
                },
                "duration": {
                  "type": "integer"
                }
              }
            },
            "description": "Games played"
          },

          "collabs": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["Hera", "Ludwig", "Linkus7", "Squeex", "Aspecticor"]
            },
            "uniqueItems": true,
            "description": "Stream Guests"
          },

          "promises": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "outcome", "status"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "outcome": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": ["o", "x", "?"],
                  "default": "?"
                }
              }
            }

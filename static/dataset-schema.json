{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "Atrioc Recap 2026 Schema",
  "type": "object",
  "required": ["vods"],
  "properties": {
    "vods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "date",
          "duration",
          "hats",
          "yok",
          "plaidShirt",
          "categories",
          "notablePeople",
          "gss",
          "gssCreators",
          "wooshed"
        ],
        "properties": {
          "id": { "type": "string", "description": "YouTube Video ID" },

          "title": { "type": "string", "description": "Title of the VOD" },

          "date": {
            "type": "string",
            "format": "date",
            "description": "The day the livestream was recorded (not the same as the VOD's upload date)"
          },

          "duration": {
            "type": "integer",
            "description": "Duration of the VOD in seconds"
          },

          "hats": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Forest Green Enron Hat",
                "Khaki Enron Hat",
                "Forest Market Cap Hat",
                "Olive Green EBITDA Hat",
                "2 Tone Dark Green Enron Hat",
                "Blue Vintage Enron Cap",
                "Khaki Bankrupt Hat",
                "Spirit Airlines Hat",
                "FTX Hat"
              ]
            },
            "uniqueItems": true
          },

          "yok": {
            "type": "integer",
            "default": 0,
            "description": "How many times he crashed out on chatters"
          },

          "plaidShirt": {
            "type": "integer",
            "default": 0,
            "description": "How many different plaid shirts he wore"
          },

          "categories": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Waffling",
                "Reacting",
                "Presentation",
                "Gaming",
                "Lakers Watch Party"
              ]
            },
            "uniqueItems": true,
            "minItems": 1,
            "description": "Stream categories"
          },

          "notablePeople": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Donald Trump",
                "Jimmy Simpson",
                "Nathan Fielder",
                "Faker",
                "Ali Khamenei",
                "Zohran Mamdani",
                "Nicolas Maduro",
                "Vladimir Putin",
                "Thomas Massie",
                "Pam Bondi",
                "Marjorie Taylor Greene",
                "Xi Jinping",
                "Sanae Takaichi",
                "Marco Rubio",
                "Tulsi Gabbard",
                "Pete Hegseth",
                "Volodymyr Zelenskyy",
                "Lai Ching-te",
                "Elon Musk",
                "Benjamin Netanyahu",
                "Kevin Warsh",
                "Jerome Powell",
                "Nigel Farage",
                "Ro Khanna",
                "Friedrich Merz",
                "Maria Machado",
                "Gustavo Petro"
              ]
            },
            "uniqueItems": true,
            "description": "Notable people mentioned in a noteworthy context and/or for a significant amount of time"
          },

          "gss": {
            "type": "integer",
            "default": 0,
            "description": "Number of GSS-like videos watched"
          },
          "gssCreators": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "How Money Works",
                "MegaLag",
                "Howtown",
                "fern",
                "Coffeezilla",
                "Good Work",
                "Almost Friday"
              ]
            },
            "uniqueItems": true,
            "description": "Notable GSS-like video creators that appeared"
          },

          "perAtrioc": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true,
            "description": "Quotes"
          },

          "wooshed": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Chatters that appeared on screen"
          },

          "games": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "duration"],
              "properties": {
                "name": {
                  "type": "string",
                  "enum": [
                    "Warcraft III",
                    "Age of Empires II",
                    "Hitman 3",
                    "007 First Light",
                    "Monkey Ball",
                    "Slay the Spire 2"
                  ]
                },
                "duration": {
                  "type": "integer"
                }
              }
            },
            "description": "Games played"
          },

          "collabs": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["Hera"]
            },
            "uniqueItems": true,
            "description": "Stream Guests"
          },

          "promises": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "outcome", "status"],
              "properties": {
                "name": {
                  "type": "string"
                },
                "outcome": {
                  "type": "string"
                },
                "status": {
                  "type": "string",
                  "enum": ["o", "x", "?"],
                  "default": "?"
                }
              }
            }
          }
        }
      }
    }
  }
}

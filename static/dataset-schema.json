{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "Atrioc Recap 2026 Schema",
  "type": "object",
  "required": ["vods"],
  "properties": {
    "vods": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "date",
          "duration",
          "hats",
          "yok",
          "plaidShirt",
          "categories",
          "notablePeople",
          "gss",
          "gssCreators",
          "wooshed"
        ],
        "properties": {
          "id": { "type": "string", "description": "YouTube Video ID" },

          "title": { "type": "string", "description": "Title of the VOD" },

          "date": {
            "type": "string",
            "format": "date",
            "description": "The day the livestream was recorded (not the same as the VOD's upload date)"
          },

          "duration": {
            "type": "integer",
            "description": "Duration of the VOD in seconds"
          },

          "hats": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Forest Green Enron Hat",
                "Khaki Enron Hat",
                "Forest Market Cap Hat",
                "Black Market Cap Hat",
                "Olive Green EBITDA Hat",
                "2 Tone Dark Green Enron Hat",
                "Blue Vintage Enron Cap",
                "Khaki Bankrupt Hat",
                "Spirit Airlines Hat",
                "FTX Hat",
                "Lakers Enron Hat"
              ]
            },
            "uniqueItems": true
          },

          "yok": {
            "type": "integer",
            "default": 0,
            "description": "How many times he crashed out on chatters"
          },

          "plaidShirt": {
            "type": "integer",
            "default": 0,
            "description": "How many different plaid shirts he wore"
          },

          "categories": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Waffling",
                "Reacting",
                "Presentation",
                "Interview",
                "Gaming",
                "Live React",
                "Lakers Watch Party",
                "Gym",
                "Special Event",
                "Daily Games",
                "Tier List"
              ]
            },
            "uniqueItems": true,
            "minItems": 1,
            "description": "Stream categories"
          },

          "notablePeople": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Donald Trump",
